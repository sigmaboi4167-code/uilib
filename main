-- Movement variables
local walkspeedEnabled = false
local walkspeedValue = 16
local jumpPowerEnabled = false
local jumpPowerValue = 50
local noclipEnabled = false
local noclipConn = nil
local flyEnabled = false
local flySpeed = 50
local flying = false
local flyBodyVelocity = nil
local flyBodyGyro = nil
local flyConn = nil
local vehicleFlyEnabled = false
local vehicleFlySpeed = 80
local vehicleFlying = false
local vehicleFlyBodyVelocity = nil
local vehicleFlyBodyGyro = nil
local vehicleFlyConn = nil
local currentVehicleSeat = nil
local infJumpEnabled = false
local infJumpConn = nil
local antiFlingEnabled = false
local antiFlingMaxVel = 100
local antiFlingConn = nil

local MiscSection = MiscPage:Section({Name = "Movement", Side = 1})

MiscSection:Toggle({Name = "Walkspeed", Flag = "WalkspeedToggle", Default = false, Callback = function(v)
    walkspeedEnabled = v
    if v and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = walkspeedValue
    elseif not v and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = 16
    end
end})
MiscSection:Slider({Name = "Walkspeed Value", Flag = "WalkspeedVal", Min = 16, Max = 250, Default = 16, Callback = function(v)
    walkspeedValue = v
    if walkspeedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = v
    end
end})

MiscSection:Toggle({Name = "Jump Power", Flag = "JumpPowerToggle", Default = false, Callback = function(v)
    jumpPowerEnabled = v
    if v and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.JumpPower = jumpPowerValue
    elseif not v and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.JumpPower = 50
    end
end})
MiscSection:Slider({Name = "Jump Power Value", Flag = "JumpPowerVal", Min = 50, Max = 350, Default = 50, Callback = function(v)
    jumpPowerValue = v
    if jumpPowerEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.JumpPower = v
    end
end})

MiscSection:Toggle({Name = "Noclip", Flag = "Noclip", Default = false, Callback = function(v)
    noclipEnabled = v
    if noclipConn then noclipConn:Disconnect() end
    if v then
        noclipConn = RunService.Stepped:Connect(function()
            if not noclipEnabled then return end
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        noclipConn = nil
    end
end})

MiscSection:Toggle({Name = "Anti-Fling", Flag = "AntiFling", Default = false, Callback = function(v)
    antiFlingEnabled = v
    if antiFlingConn then antiFlingConn:Disconnect() end
    if v then
        antiFlingConn = RunService.Heartbeat:Connect(function()
            if not antiFlingEnabled then return end
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local vel = hrp.AssemblyLinearVelocity
                if vel.Magnitude > antiFlingMaxVel then
                    hrp.AssemblyLinearVelocity = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end)
    end
end})

MiscSection:Toggle({Name = "Infinite Jump", Flag = "InfJump", Default = false, Callback = function(v)
    infJumpEnabled = v
    if infJumpConn then infJumpConn:Disconnect() end
    if v then
        infJumpConn = UserInputService.JumpRequest:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
end})

MiscSection:Toggle({Name = "Fly", Flag = "FlyToggle", Default = false, Callback = function(v)
    flyEnabled = v
    if flyConn then flyConn:Disconnect() end
    if v then
        local function startFly()
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not humanoid then return end
            
            flying = true
            humanoid.PlatformStand = true
            
            flyBodyVelocity = Instance.new("BodyVelocity")
            flyBodyVelocity.Velocity = Vector3.zero
            flyBodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            flyBodyVelocity.Parent = hrp
            
            flyBodyGyro = Instance.new("BodyGyro")
            flyBodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
            flyBodyGyro.P = 1e4
            flyBodyGyro.CFrame = hrp.CFrame
            flyBodyGyro.Parent = hrp
        end
        
        local function stopFly()
            flying = false
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then humanoid.PlatformStand = false end
            end
            if flyBodyVelocity then flyBodyVelocity:Destroy() end
            if flyBodyGyro then flyBodyGyro:Destroy() end
            flyBodyVelocity = nil
            flyBodyGyro = nil
        end
        
        local function updateFly()
            if not flying then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            
            local moveVector = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end
            
            if moveVector.Magnitude > 0 then
                moveVector = moveVector.Unit * flySpeed
            end
            
            if flyBodyVelocity then flyBodyVelocity.Velocity = moveVector end
            if flyBodyGyro then flyBodyGyro.CFrame = Camera.CFrame end
        end
        
        startFly()
        flyConn = RunService.Heartbeat:Connect(updateFly)
        
        LocalPlayer.CharacterAdded:Connect(function(newChar)
            if flyEnabled then
                task.wait(0.5)
                startFly()
            end
        end)
    else
        if flyConn then flyConn:Disconnect() end
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid.PlatformStand = false end
        end
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
        if flyBodyGyro then flyBodyGyro:Destroy() end
        flyBodyVelocity = nil
        flyBodyGyro = nil
        flyConn = nil
        flying = false
    end
end})
MiscSection:Slider({Name = "Fly Speed", Flag = "FlySpeed", Min = 10, Max = 250, Default = 50, Callback = function(v) flySpeed = v end})

MiscSection:Toggle({Name = "Vehicle Fly", Flag = "VehicleFly", Default = false, Callback = function(v)
    vehicleFlyEnabled = v
    if vehicleFlyConn then vehicleFlyConn:Disconnect() end
    if v then
		Library:Notification("loaded", "nigere", 10)
        local function getVehicleSeat()
            local char = LocalPlayer.Character
            if not char then return nil end
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
                return humanoid.SeatPart
            end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("VehicleSeat") then return part end
            end
            return nil
        end
        
        local function startVehicleFly(seat)
            if not seat then return end
            vehicleFlying = true
            currentVehicleSeat = seat
            seat.Throttle = 0
            seat.Steer = 0
            
            local rootPart = seat.Parent:FindFirstChild("VehicleRootPart") or seat
            vehicleFlyBodyVelocity = Instance.new("BodyVelocity")
            vehicleFlyBodyVelocity.Velocity = Vector3.zero
            vehicleFlyBodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
            vehicleFlyBodyVelocity.Parent = rootPart
            
            vehicleFlyBodyGyro = Instance.new("BodyGyro")
            vehicleFlyBodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
            vehicleFlyBodyGyro.P = 1e5
            vehicleFlyBodyGyro.CFrame = rootPart.CFrame
            vehicleFlyBodyGyro.Parent = rootPart
        end
        
        local function stopVehicleFly()
            vehicleFlying = false
            if vehicleFlyBodyVelocity then vehicleFlyBodyVelocity:Destroy() end
            if vehicleFlyBodyGyro then vehicleFlyBodyGyro:Destroy() end
            vehicleFlyBodyVelocity = nil
            vehicleFlyBodyGyro = nil
            if currentVehicleSeat then
                currentVehicleSeat.Throttle = 0
                currentVehicleSeat.Steer = 0
            end
            currentVehicleSeat = nil
        end
        
        local function updateVehicleFly()
            if not vehicleFlying or not currentVehicleSeat then return end
            local rootPart = currentVehicleSeat.Parent:FindFirstChild("VehicleRootPart") or currentVehicleSeat
            local moveVector = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end
            
            if moveVector.Magnitude > 0 then
                moveVector = moveVector.Unit * vehicleFlySpeed
            end
            
            if vehicleFlyBodyVelocity then vehicleFlyBodyVelocity.Velocity = moveVector end
            if vehicleFlyBodyGyro then vehicleFlyBodyGyro.CFrame = Camera.CFrame end
        end
        
        local seatCheckConn
        seatCheckConn = RunService.Heartbeat:Connect(function()
            if not vehicleFlyEnabled then
                if seatCheckConn then seatCheckConn:Disconnect() end
                return
            end
            local seat = getVehicleSeat()
            if seat and not vehicleFlying then
                startVehicleFly(seat)
            elseif not seat and vehicleFlying then
                stopVehicleFly()
            end
        end)
        
        vehicleFlyConn = RunService.Heartbeat:Connect(updateVehicleFly)
    else
        if vehicleFlyConn then vehicleFlyConn:Disconnect() end
        stopVehicleFly()
        vehicleFlyConn = nil
    end
end})
MiscSection:Slider({Name = "Vehicle Fly Speed", Flag = "VehicleFlySpeed", Min = 10, Max = 300, Default = 80, Callback = function(v) vehicleFlySpeed = v end})

local ESPPreviewSection = VisualsPage:Section({Name = "ESP Preview", Side = 2})
ESPPreviewSection:ESPDummy()

Library:Notification("EpsteinWare", "loaded properly", 5)

Players.PlayerAdded:Connect(function(p)
    if p ~= LocalPlayer then
        if boxToggle then CreateBoxESP(p) end
        if healthToggle then CreateHealthBarESP(p) end
        if tracerToggle then CreateTracerESP(p) end
        if skeletonToggle then CreateSkeletonESP(p) end
        if arrowToggle then CreateArrowESP(p) end
        if box3DToggle then Create3DBoxESP(p) end
    end
end)
