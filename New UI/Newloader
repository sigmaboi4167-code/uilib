		thumbFrame.BackgroundColor3 = Theme.Background
		thumbFrame.BorderSizePixel  = 0
		thumbFrame.ZIndex           = 8
		thumbFrame.ClipsDescendants = true
		thumbFrame.Parent           = row
		addStroke(thumbFrame, Theme.Outline)
		addCorner(thumbFrame, 4)

