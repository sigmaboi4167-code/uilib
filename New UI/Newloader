-- Snowfall
-- ────────────────────────────────────────────────

local SNOW_COUNT = 28

local function makeSnowflake(parent, winW, winH)
	local size  = math.random(2, 5)
	local startX = math.random(0, winW)
	local speed  = math.random(18, 38) -- pixels per second (slower = nicer)
	local drift  = math.random(-12, 12)
	local alpha  = math.random(30, 70) / 100

	local flake = Instance.new("Frame")
	flake.Size               = UDim2.new(0, size, 0, size)
	flake.Position           = UDim2.new(0, startX, 0, math.random(-winH, 0))
	flake.BackgroundColor3   = Theme.Snow
	flake.BackgroundTransparency = 1 - alpha
	flake.BorderSizePixel    = 0
	flake.ZIndex             = 5
	flake.Parent             = parent
	addCorner(flake, size)

	return { frame = flake, x = startX, y = flake.Position.Y.Offset, speed = speed, drift = drift, size = size, winW = winW, winH = winH }
end

local function startSnow(parent, winW, winH)
	local flakes = {}
	for _ = 1, SNOW_COUNT do
		local f = makeSnowflake(parent, winW, winH)
		-- scatter initial Y so they don't all start at top at once
		f.y = math.random(-winH, winH)
		f.frame.Position = UDim2.new(0, f.x, 0, f.y)
		table.insert(flakes, f)
	end

	local last = os.clock()
	track(RunService.RenderStepped:Connect(function()
		local now = os.clock()
		local dt  = now - last
		last      = now

		for _, f in ipairs(flakes) do
			f.y = f.y + f.speed * dt
			f.x = f.x + f.drift * dt * 0.3

			-- wrap back to top when off screen
			if f.y > f.winH + 10 then
				f.y = -f.size - 2
				f.x = math.random(0, f.winW)
			end
			if f.x < -f.size then f.x = f.winW + f.size end
			if f.x > f.winW + f.size then f.x = -f.size end

			f.frame.Position = UDim2.new(0, f.x, 0, f.y)
		end
	end))
end

