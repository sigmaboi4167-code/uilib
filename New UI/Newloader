-- ────────────────────────────────────────────────
-- Utilities
-- ────────────────────────────────────────────────

local function xorStr(s)
	local out = {}
	for i = 1, #s do
		out[i] = string.char(bit32.bxor(string.byte(s, i), XOR_BYTE))
	end
	return table.concat(out)
end

local function formatTime(seconds)
	if seconds == math.huge then return "Lifetime" end
	local d = math.floor(seconds / 86400)
	local h = math.floor((seconds % 86400) / 3600)
	local m = math.floor((seconds % 3600) / 60)
	if d > 0 then return d .. "d " .. h .. "h"
	elseif h > 0 then return h .. "h " .. m .. "m"
	else return m .. "m" end
end

local function checkKey(input)
	for tier, keys in pairs(ALL_KEYS) do
		for _, v in ipairs(keys) do
			if v == input then return tier end
		end
	end
end

-- ────────────────────────────────────────────────
-- Key Storage
-- ────────────────────────────────────────────────

local function saveKey(key, expiry)
	if not isfolder(FOLDER) then makefolder(FOLDER) end
	writefile(KEYFILE, xorStr(key .. "|" .. tostring(expiry)))
end

local function loadSavedKey()
	if not isfile(KEYFILE) then return nil end
	local ok, raw = pcall(function() return xorStr(readfile(KEYFILE)) end)
	if not ok then return nil end
	local key, expiry = raw:match("^(.+)|(%d+%.?%d*)$")
	if not key then return nil end
	return key, tonumber(expiry)
end

local function deleteSavedKey()
	pcall(function() delfile(KEYFILE) end)
	pcall(function() deletefile(KEYFILE) end)
end

