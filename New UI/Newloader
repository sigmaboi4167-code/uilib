		deselectAll()
		selectedIdx = idx
		local r = rows[idx]
		tween(r.frame, { BackgroundColor3 = Color3.fromRGB(38, 48, 42) })
		tween(r.stroke, { Color = Color3.fromRGB(200, 215, 205), Transparency = 0.45 })
		r.nameLabel.TextColor3 = Color3.fromRGB(220, 235, 225)
		tween(loadBtn, { BackgroundColor3 = Color3.fromRGB(50, 60, 54) })
