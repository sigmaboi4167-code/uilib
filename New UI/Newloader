function EWare.new()
	return setmetatable({ _dead = false }, EWare)
end

function EWare:Unload()
	self._dead = true
	for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
	connections = {}
	if activeGui then pcall(function() activeGui:Destroy() end) activeGui = nil end
	UserInputService.MouseIconEnabled = true
	getgenv().EWareLoaded = nil
end

