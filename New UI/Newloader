	local ROW_GAP  = 6
	local LIST_PAD = 10
	local HEADER_H = 58
	local WIN_W    = 420
	local totalRows = #GAMES
	local listH    = totalRows * ROW_H + (totalRows - 1) * ROW_GAP + LIST_PAD * 2
	local winH     = math.min(math.max(HEADER_H + listH + 14, 240), 480)

	if not isfolder(FOLDER) then makefolder(FOLDER) end

	makeCursor(gui)
	local win     = makeWindow(gui, WIN_W, winH)
	startSnow(win, WIN_W, winH)
	local sidebar = makeSidebar(win, tier, timeLeft)
	local content = makeContent(win)

	-- Load button
	local loadBtn = makeButton(sidebar, UDim2.new(0.5, 0, 0, 96), UDim2.new(1, -12, 0, 22))
	loadBtn.AnchorPoint = Vector2.new(0.5, 0)
	loadBtn.ZIndex = 8
	addHoverEffect(loadBtn)
	local loadTxt = makeLabel(loadBtn, "load", 9, Theme.Text)
	loadTxt.AnchorPoint    = Vector2.new(0.5, 0.5)
	loadTxt.Position       = UDim2.new(0.5, 0, 0.5, 0)
	loadTxt.TextXAlignment = Enum.TextXAlignment.Center
	loadTxt.ZIndex         = 9

	-- Remove key button
	local removeBtn = makeButton(sidebar, UDim2.new(0.5, 0, 0, 124), UDim2.new(1, -12, 0, 22))
	removeBtn.AnchorPoint = Vector2.new(0.5, 0)
	removeBtn.ZIndex = 8
	local removeTxt = makeLabel(removeBtn, "log out", 8, Theme.Error)
	removeTxt.AnchorPoint    = Vector2.new(0.5, 0.5)
	removeTxt.Position       = UDim2.new(0.5, 0, 0.5, 0)
	removeTxt.TextXAlignment = Enum.TextXAlignment.Center
	removeTxt.ZIndex         = 9
	track(removeBtn.MouseEnter:Connect(function() tween(removeBtn, { BackgroundColor3 = Color3.fromRGB(50, 24, 24) }) end))
	track(removeBtn.MouseLeave:Connect(function() tween(removeBtn, { BackgroundColor3 = Theme.Element }) end))

	-- Game list
	local listFrame = Instance.new("ScrollingFrame")
	listFrame.Position               = UDim2.new(0, 0, 0, 56)
	listFrame.Size                   = UDim2.new(1, 0, 1, -64)
	listFrame.BackgroundTransparency = 1
	listFrame.BorderSizePixel        = 0
	listFrame.ScrollBarThickness     = 2
	listFrame.ScrollBarImageColor3   = Theme.Accent
	listFrame.CanvasSize             = UDim2.new(0, 0, 0, 0)
	listFrame.AutomaticCanvasSize    = Enum.AutomaticSize.Y
	listFrame.ClipsDescendants       = true
	listFrame.ZIndex                 = 7
	listFrame.Parent                 = content

	local layout = Instance.new("UIListLayout")
	layout.Padding   = UDim.new(0, ROW_GAP)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent    = listFrame
	addPadding(listFrame, LIST_PAD, LIST_PAD, 0, 2)

	local selectedIdx = nil
	local rows        = {}

	local function deselectAll()
		for _, r in pairs(rows) do
			tween(r.frame, { BackgroundColor3 = r.hovered and Theme.Hovered or Theme.Element })
			tween(r.stroke, { Color = Theme.Outline, Transparency = 0 })
			r.nameLabel.TextColor3 = Theme.Text
		end
	end

