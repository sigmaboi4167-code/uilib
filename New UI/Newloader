		thumbImg.Image      = ""
		thumbImg.ZIndex     = 9
		thumbImg.Parent     = thumbFrame
		addCorner(thumbImg, 4)

		if game.thumbnail and game.thumbnail ~= "" then
			task.spawn(function()
				local fname = FOLDER .. "/thumb_" .. i .. ".png"
				if not isfile(fname) then
					local ok, data = pcall(function()
						return (http and http.request or request or httprequest)({
							Url    = game.thumbnail,
							Method = "GET",
						})
					end)
					if ok and data and data.Body and data.Body ~= "" then
						writefile(fname, data.Body)
					end
				end
				if isfile(fname) then
					local ok2, asset = pcall(getcustomasset, fname)
					if ok2 and asset then thumbImg.Image = asset end
				end
			end)
		end

		-- Game name
		local nameLabel = makeLabel(row, game.name, 13, Theme.Text)
		nameLabel.AnchorPoint = Vector2.new(0, 0.5)
		nameLabel.Position    = UDim2.new(0, 120, 0.5, -10)
		nameLabel.ZIndex      = 9

		-- Status
		local statusLabel = makeLabel(row, game.status, 10, game.color)
		statusLabel.AnchorPoint      = Vector2.new(0, 0.5)
		statusLabel.Position         = UDim2.new(0, 120, 0.5, 8)
		statusLabel.TextXAlignment   = Enum.TextXAlignment.Left
		statusLabel.TextTransparency = 0.15
		statusLabel.ZIndex           = 9

		rows[i] = { frame = row, stroke = rowStroke, nameLabel = nameLabel, url = game.url, hovered = false }

		track(row.MouseEnter:Connect(function()
			rows[i].hovered = true
			if selectedIdx ~= i then tween(row, { BackgroundColor3 = Theme.Hovered }) end
		end))
		track(row.MouseLeave:Connect(function()
			rows[i].hovered = false
			if selectedIdx ~= i then tween(row, { BackgroundColor3 = Theme.Element }) end
		end))
		track(row.MouseButton1Down:Connect(function() selectRow(i) end))
	end

	-- Confirm overlay
	local confirmOverlay = Instance.new("Frame")
	confirmOverlay.Size                  = UDim2.new(1, 0, 1, 0)
	confirmOverlay.BackgroundColor3      = Theme.Background
	confirmOverlay.BackgroundTransparency = 0.1
	confirmOverlay.BorderSizePixel       = 0
	confirmOverlay.ZIndex                = 200
	confirmOverlay.Visible               = false
	confirmOverlay.Parent                = win

	local confirmBox = Instance.new("Frame")
	confirmBox.AnchorPoint      = Vector2.new(0.5, 0.5)
	confirmBox.Position         = UDim2.new(0.5, 0, 0.5, 0)
	confirmBox.Size             = UDim2.new(0, 220, 0, 90)
	confirmBox.BackgroundColor3 = Theme.Inline
	confirmBox.BorderSizePixel  = 0
	confirmBox.ZIndex           = 201
	confirmBox.Parent           = confirmOverlay
	addStroke(confirmBox, Theme.Outline)
	addCorner(confirmBox, 5)

	local confirmTitle = makeLabel(confirmBox, "log out?", 11, Theme.Text)
	confirmTitle.AnchorPoint    = Vector2.new(0.5, 0)
	confirmTitle.Position       = UDim2.new(0.5, 0, 0, 14)
	confirmTitle.TextXAlignment = Enum.TextXAlignment.Center
	confirmTitle.ZIndex         = 202

	local confirmSub = makeLabel(confirmBox, "you will be sent back to key screen", 9, Theme.Placeholder)
	confirmSub.AnchorPoint      = Vector2.new(0.5, 0)
	confirmSub.Position         = UDim2.new(0.5, 0, 0, 30)
	confirmSub.TextXAlignment   = Enum.TextXAlignment.Center
	confirmSub.TextTransparency = 0.35
	confirmSub.ZIndex           = 202

	local yesBtn = makeButton(confirmBox, UDim2.new(0, 12, 0, 56), UDim2.new(0, 90, 0, 22))
	yesBtn.ZIndex = 202
	local yesTxt = makeLabel(yesBtn, "yes, log out", 9, Theme.Error)
	yesTxt.AnchorPoint    = Vector2.new(0.5, 0.5)
	yesTxt.Position       = UDim2.new(0.5, 0, 0.5, 0)
	yesTxt.TextXAlignment = Enum.TextXAlignment.Center
	yesTxt.ZIndex         = 203
	track(yesBtn.MouseEnter:Connect(function() tween(yesBtn, { BackgroundColor3 = Color3.fromRGB(50, 24, 24) }) end))
	track(yesBtn.MouseLeave:Connect(function() tween(yesBtn, { BackgroundColor3 = Theme.Element }) end))

	local noBtn = makeButton(confirmBox, UDim2.new(1, -102, 0, 56), UDim2.new(0, 90, 0, 22))
	noBtn.ZIndex = 202
	local noTxt = makeLabel(noBtn, "cancel", 9, Theme.Text)
	noTxt.AnchorPoint    = Vector2.new(0.5, 0.5)
	noTxt.Position       = UDim2.new(0.5, 0, 0.5, 0)
	noTxt.TextXAlignment = Enum.TextXAlignment.Center
	noTxt.ZIndex         = 203
	addHoverEffect(noBtn)

	-- Close button
	local closeBtn = makeButton(sidebar, UDim2.new(0.5, 0, 0, 152), UDim2.new(1, -12, 0, 22))
	closeBtn.AnchorPoint = Vector2.new(0.5, 0)
	closeBtn.ZIndex = 8
	local closeTxt = makeLabel(closeBtn, "close", 9, Theme.Placeholder)
	closeTxt.AnchorPoint    = Vector2.new(0.5, 0.5)
	closeTxt.Position       = UDim2.new(0.5, 0, 0.5, 0)
	closeTxt.TextXAlignment = Enum.TextXAlignment.Center
	closeTxt.ZIndex         = 9
	track(closeBtn.MouseEnter:Connect(function()
		tween(closeBtn, { BackgroundColor3 = Theme.Hovered })
		closeTxt.TextColor3 = Theme.Text
	end))
	track(closeBtn.MouseLeave:Connect(function()
		tween(closeBtn, { BackgroundColor3 = Theme.Element })
		closeTxt.TextColor3 = Theme.Placeholder
	end))
	track(closeBtn.MouseButton1Down:Connect(function()
		self:Unload()
	end))

	track(removeBtn.MouseButton1Down:Connect(function()
		confirmOverlay.Visible = true
	end))
	track(noBtn.MouseButton1Down:Connect(function()
		confirmOverlay.Visible = false
	end))
	track(yesBtn.MouseButton1Down:Connect(function()
		deleteSavedKey()
		confirmOverlay.Visible = false
		self:Unload()
		local newInst = EWare.new()
		getgenv().EWareLoaded = newInst
		newInst:Build()
	end))

	track(loadBtn.MouseButton1Down:Connect(function()
		if not selectedIdx then return end
		local r = rows[selectedIdx]
		if not r or r.url == "" then return end
		tween(loadBtn, { BackgroundColor3 = Theme.Accent })
		task.wait(0.14)
		local url = r.url
		self:Unload()
		task.spawn(function()
			local src = game:HttpGet(url)
			if src and src ~= "" then
				local fn = loadstring(src)
				if fn then pcall(fn) end
			end
		end)
	end))

	makeDraggable(win)
	track(UserInputService.InputBegan:Connect(function(inp, gp)
		if not gp and inp.KeyCode == Enum.KeyCode.Delete then self:Unload() end
	end))
end

function EWare:Build()
	local gui = Instance.new("ScreenGui")
	gui.Name           = "eware_key"
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
	gui.DisplayOrder   = 10000
	gui.ResetOnSpawn   = false
	gui.IgnoreGuiInset = true
	gui.Parent         = CoreGui
	activeGui          = gui

	local WIN_W = 400
	local WIN_H = 220

	makeCursor(gui)
	local win     = makeWindow(gui, WIN_W, WIN_H)
	startSnow(win, WIN_W, WIN_H)
	local sidebar = makeSidebar(win, nil, nil)
	local content = makeContent(win)

	-- Key input
	local inputBg = Instance.new("Frame")
	inputBg.Position         = UDim2.new(0, 0, 0, 58)
	inputBg.Size             = UDim2.new(1, 0, 0, 28)
	inputBg.BackgroundColor3 = Theme.Element
	inputBg.BorderSizePixel  = 0
	inputBg.ZIndex           = 7
	inputBg.Parent           = content
	addStroke(inputBg, Theme.Outline)
	addCorner(inputBg, 3)
	addGradient(inputBg)
	track(inputBg.MouseEnter:Connect(function() tween(inputBg, { BackgroundColor3 = Theme.Hovered }) end))
	track(inputBg.MouseLeave:Connect(function() tween(inputBg, { BackgroundColor3 = Theme.Element }) end))

	local inputBox = Instance.new("TextBox")
	inputBox.BackgroundTransparency = 1
	inputBox.Size              = UDim2.new(1, 0, 1, 0)
	inputBox.FontFace          = Font.new("rbxasset://fonts/families/RobotoMono.json")
	inputBox.TextSize          = 10
	inputBox.TextColor3        = Theme.Text
	inputBox.PlaceholderColor3 = Theme.Placeholder
	inputBox.PlaceholderText   = "enter key..."
	inputBox.Text              = ""
	inputBox.ClearTextOnFocus  = false
	inputBox.TextXAlignment    = Enum.TextXAlignment.Left
	inputBox.ZIndex            = 8
	inputBox.Parent            = inputBg
	addPadding(inputBox, 0, 0, 10, 10)

	local statusLbl = makeLabel(content, "", 10, Theme.Placeholder)
	statusLbl.Position         = UDim2.new(0, 0, 0, 96)
	statusLbl.TextTransparency = 0.3
	statusLbl.ZIndex           = 7

	local authBtn = makeButton(content, UDim2.new(0, 0, 0, 116), UDim2.new(1, 0, 0, 26))
	authBtn.ZIndex = 7
	addHoverEffect(authBtn)
	local authTxt = makeLabel(authBtn, "authenticate", 10, Theme.Text)
	authTxt.AnchorPoint    = Vector2.new(0.5, 0.5)
	authTxt.Position       = UDim2.new(0.5, 0, 0.5, 0)
	authTxt.TextXAlignment = Enum.TextXAlignment.Center
	authTxt.ZIndex         = 8

	local function setStatus(msg, isError)
		statusLbl.Text       = msg
		statusLbl.TextColor3 = isError and Theme.Error or Theme.Accent
	end

	local function flashButton(success)
		tween(authBtn, { BackgroundColor3 = success and Theme.Accent or Theme.Error })
		task.wait(0.14)
		tween(authBtn, { BackgroundColor3 = Theme.Element })
	end

	local function shakeWindow()
		local base = win.Position
		task.spawn(function()
			for _, ox in ipairs({ -6, 6, -5, 5, -3, 3, 0 }) do
				win.Position = UDim2.new(base.X.Scale, base.X.Offset + ox, base.Y.Scale, base.Y.Offset)
				task.wait(0.045)
			end
		end)
	end

	local busy = false
	local function tryAuth(raw)
		if busy then return end
		raw = raw:match("^%s*(.-)%s*$")
		if raw == "" then
			setStatus("key cannot be empty", true)
			flashButton(false)
			return
		end
		local tier = checkKey(raw)
		if tier then
			busy = true
			local duration = KEY_DURATIONS[tier]
			local expiry   = duration == math.huge and math.huge or os.time() + duration
			saveKey(raw, expiry)
			setStatus("authenticated  ·  " .. formatTime(duration), false)
			flashButton(true)
			task.delay(0.7, function()
				if not self._dead then
					local timeLeft = expiry == math.huge and math.huge or (expiry - os.time())
					self:ShowGameSelect(tier, timeLeft)
				end
				busy = false
			end)
		else
			setStatus("invalid key", true)
			flashButton(false)
			shakeWindow()
		end
	end

	-- Close button
	local closeBtnKey = makeButton(content, UDim2.new(0, 0, 0, 150), UDim2.new(1, 0, 0, 22))
	closeBtnKey.ZIndex = 7
	local closeTxtKey = makeLabel(closeBtnKey, "close", 9, Theme.Placeholder)
	closeTxtKey.AnchorPoint    = Vector2.new(0.5, 0.5)
	closeTxtKey.Position       = UDim2.new(0.5, 0, 0.5, 0)
	closeTxtKey.TextXAlignment = Enum.TextXAlignment.Center
	closeTxtKey.ZIndex         = 8
	track(closeBtnKey.MouseEnter:Connect(function()
		tween(closeBtnKey, { BackgroundColor3 = Theme.Hovered })
		closeTxtKey.TextColor3 = Theme.Text
	end))
	track(closeBtnKey.MouseLeave:Connect(function()
		tween(closeBtnKey, { BackgroundColor3 = Theme.Element })
		closeTxtKey.TextColor3 = Theme.Placeholder
	end))
	track(closeBtnKey.MouseButton1Down:Connect(function()
		self:Unload()
	end))

	track(authBtn.MouseButton1Down:Connect(function() tryAuth(inputBox.Text) end))
	track(inputBox.FocusLost:Connect(function(enter) if enter then tryAuth(inputBox.Text) end end))

	makeDraggable(win)
	track(UserInputService.InputBegan:Connect(function(inp, gp)
		if not gp and inp.KeyCode == Enum.KeyCode.Delete then self:Unload() end
	end))

	local savedKey, savedExpiry = loadSavedKey()
	if savedKey and savedExpiry then
		local valid = (savedExpiry == math.huge) or (os.time() < savedExpiry)
		if valid and checkKey(savedKey) then
			local tier     = checkKey(savedKey)
			local timeLeft = savedExpiry == math.huge and math.huge or (savedExpiry - os.time())
			inputBox.Text  = savedKey
			setStatus("welcome back  ·  " .. formatTime(timeLeft), false)
			task.delay(0.9, function()
				if not self._dead then self:ShowGameSelect(tier, timeLeft) end
			end)
		else
			deleteSavedKey()
			setStatus("key expired  ·  enter a new one", true)
		end
	end
end

